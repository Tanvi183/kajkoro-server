// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────

enum Role {
  WORKER
  EMPLOYER
  ADMIN
}

enum JobStatus {
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  EARNING
  REFUND
  REFERRAL_BONUS
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ──────────────────────────────────────────
// MODELS
// ──────────────────────────────────────────

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String?  @unique
  password   String
  avatar     String?
  role       Role     @default(WORKER)
  balance    Decimal  @default(0) @db.Decimal(12, 2)
  isVerified Boolean  @default(false)
  isBanned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  jobsPosted     Job[]           @relation("EmployerJobs")
  submissions    Submission[]
  transactions   Transaction[]
  withdrawals    Withdrawal[]
  notifications  Notification[]
  supportTickets SupportTicket[]
  referralsMade  Referral[]      @relation("Referrer")
  referredBy     Referral?       @relation("Referred")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("#059669")
  icon      String?
  jobs      Job[]
  createdAt DateTime @default(now())
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description String
  reward      Decimal   @db.Decimal(10, 2)
  totalSlots  Int
  slotsLeft   Int
  status      JobStatus @default(ACTIVE)
  country     String?

  // Relations
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])
  employerId  String
  employer    User         @relation("EmployerJobs", fields: [employerId], references: [id])
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Submission {
  id       String           @id @default(uuid())
  proofUrl String
  note     String?
  status   SubmissionStatus @default(PENDING)

  // Relations
  jobId    String
  job      Job    @relation(fields: [jobId], references: [id])
  workerId String
  worker   User   @relation(fields: [workerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobId, workerId])
}

model Transaction {
  id          String          @id @default(uuid())
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Withdrawal {
  id            String           @id @default(uuid())
  amount        Decimal          @db.Decimal(12, 2)
  method        String
  accountNumber String
  status        WithdrawalStatus @default(PENDING)
  adminNote     String?

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id      String  @id @default(uuid())
  title   String
  message String
  isRead  Boolean @default(false)
  link    String?

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Referral {
  id    String  @id @default(uuid())
  bonus Decimal @default(0) @db.Decimal(10, 2)

  // Relations
  referrerId String
  referrer   User   @relation("Referrer", fields: [referrerId], references: [id])
  referredId String @unique
  referred   User   @relation("Referred", fields: [referredId], references: [id])

  createdAt DateTime @default(now())
}

model SupportTicket {
  id      String       @id @default(uuid())
  subject String
  message String
  status  TicketStatus @default(OPEN)
  reply   String?

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id      String  @id @default(uuid())
  name    String
  email   String
  message String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())
}
